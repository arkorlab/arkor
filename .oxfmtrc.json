{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortPackageJson": false,
  "sortImports": false,
  "ignorePatterns": [
    ".claude/**",
    "**/*.md",
    "**/*.mdx",
    "**/*.yaml",
    "**/*.yml"
  ]
}
