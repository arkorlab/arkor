{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    "eslint.config.ts",
    "oxlint.config.ts"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "ARKOR_POSTHOG_KEY",
        "ARKOR_POSTHOG_HOST",
        "CREATE_ARKOR_BUILD_SOURCEMAP"
      ],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "env": [
        "ARKOR_E2E_PM",
        "ARKOR_INTERNAL_SCAFFOLD_ARKOR_SPEC",
        "ARKOR_POSTHOG_KEY",
        "ARKOR_POSTHOG_HOST",
        "ARKOR_TELEMETRY_DISABLED",
        "CREATE_ARKOR_BUILD_SOURCEMAP",
        "PLAYWRIGHT_BROWSERS_PATH",
        "PWDEBUG",
        "SKIP_E2E_INSTALL",
        "STUDIO_E2E_DEBUG"
      ],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "env": [
        "ARKOR_E2E_PM",
        "ARKOR_INTERNAL_SCAFFOLD_ARKOR_SPEC",
        "ARKOR_POSTHOG_KEY",
        "ARKOR_POSTHOG_HOST",
        "ARKOR_TELEMETRY_DISABLED",
        "CREATE_ARKOR_BUILD_SOURCEMAP",
        "PLAYWRIGHT_BROWSERS_PATH",
        "PWDEBUG",
        "SKIP_E2E_INSTALL",
        "STUDIO_E2E_DEBUG"
      ],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
