{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["ARKOR_POSTHOG_KEY", "ARKOR_POSTHOG_HOST"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": [
        "ARKOR_INTERNAL_SCAFFOLD_ARKOR_SPEC",
        "ARKOR_POSTHOG_KEY",
        "ARKOR_POSTHOG_HOST",
        "ARKOR_TELEMETRY_DISABLED",
        "SKIP_E2E_INSTALL"
      ],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "env": [
        "ARKOR_INTERNAL_SCAFFOLD_ARKOR_SPEC",
        "ARKOR_POSTHOG_KEY",
        "ARKOR_POSTHOG_HOST",
        "ARKOR_TELEMETRY_DISABLED",
        "SKIP_E2E_INSTALL"
      ],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
