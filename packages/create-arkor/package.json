{
  "name": "create-arkor",
  "version": "0.0.3-alpha.1",
  "description": "Scaffolder for arkor training projects.",
  "private": false,
  "type": "module",
  "homepage": "https://github.com/arkorlab/arkor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arkorlab/arkor.git",
    "directory": "packages/create-arkor"
  },
  "bugs": {
    "url": "https://github.com/arkorlab/arkor/issues"
  },
  "license": "MIT",
  "keywords": [
    "arkor",
    "create",
    "scaffold",
    "template"
  ],
  "bin": {
    "create-arkor": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "CONTRIBUTING.md",
    "README.ja.md"
  ],
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit && tsdown && node scripts/copy-root-files.mjs",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --deny-warnings . && eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --passWithNoTests --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@arkor/cli-internal": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
