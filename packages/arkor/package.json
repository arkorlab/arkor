{
  "name": "arkor",
  "version": "0.0.2-alpha.2",
  "description": "Code-first TypeScript training SDK, CLI, and local Studio.",
  "private": false,
  "type": "module",
  "homepage": "https://github.com/arkorlab/arkor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arkorlab/arkor.git",
    "directory": "packages/arkor"
  },
  "bugs": {
    "url": "https://github.com/arkorlab/arkor/issues"
  },
  "license": "MIT",
  "keywords": [
    "arkor",
    "llm",
    "lora",
    "fine-tuning",
    "training",
    "sdk",
    "cli"
  ],
  "bin": {
    "arkor": "./dist/bin.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "CONTRIBUTING.md",
    "README.ja.md"
  ],
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "pnpm --filter @arkor/studio-app bundle && tsc -p tsconfig.build.json --noEmit && tsdown && node scripts/copy-studio-assets.mjs && node scripts/copy-root-files.mjs && node scripts/copy-docs.mjs",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --deny-warnings .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@arkor/cloud-api-client": "catalog:",
    "@clack/prompts": "catalog:",
    "@hono/node-server": "catalog:",
    "commander": "catalog:",
    "esbuild": "catalog:",
    "hono": "catalog:",
    "open": "catalog:",
    "posthog-node": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@arkor/cli-internal": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
