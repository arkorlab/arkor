{
  "name": "arkor",
  "version": "0.0.1-alpha.5",
  "description": "Code-first TypeScript training SDK, CLI, and local Studio.",
  "private": false,
  "type": "module",
  "homepage": "https://github.com/arkorlab/arkor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arkorlab/arkor.git",
    "directory": "packages/arkor"
  },
  "bugs": {
    "url": "https://github.com/arkorlab/arkor/issues"
  },
  "license": "MIT",
  "keywords": [
    "arkor",
    "llm",
    "lora",
    "fine-tuning",
    "training",
    "sdk",
    "cli"
  ],
  "bin": {
    "arkor": "./dist/bin.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "CONTRIBUTING.md",
    "README.ja.md"
  ],
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "build": "pnpm --filter @arkor/studio-app bundle && tsc -p tsconfig.build.json --noEmit && tsdown && node scripts/copy-studio-assets.mjs && node scripts/copy-root-files.mjs && node scripts/copy-docs.mjs",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@arkor/cloud-api-client": "^0.0.1-alpha.1",
    "@clack/prompts": "^0.8.0",
    "@hono/node-server": "^1.14.0",
    "commander": "^13.0.0",
    "esbuild": "^0.28.0",
    "hono": "^4.7.0",
    "open": "^10.0.0",
    "posthog-node": "^5.30.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@arkor/cli-internal": "workspace:*",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^4.1.5",
    "tsdown": "^0.21.9",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
