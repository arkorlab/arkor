# Dependencies
node_modules/

# Build
dist/

# Generated copies of root files (see packages/*/scripts/copy-root-files.mjs)
packages/*/CONTRIBUTING.md
packages/*/README.ja.md

# Generated copy of docs/ (see packages/arkor/scripts/copy-docs.mjs)
packages/arkor/docs/

# Turbo
.turbo/

# Vitest coverage reports (uploaded to Codecov in CI)
coverage/

# Playwright run artefacts (HTML reports, traces, videos, screenshots,
# `.last-run.json`). The JUnit XML inside e2e/studio/coverage/ is uploaded
# to Codecov by CI, so it doesn't need to be tracked either.
playwright-report/
test-results/

# Raw V8 coverage data emitted by NODE_V8_COVERAGE for E2E coverage
.v8-coverage/

# Mintlify (docs/) local cache
.mintlify/
.mint/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
